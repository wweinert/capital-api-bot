{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SignalQuality",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "symbol",
    "strategyFamily",
    "direction",
    "decision",
    "signalQuality",
    "confidence",
    "expectedR",
    "riskPct",
    "reason",
    "warnings"
  ],
  "properties": {
    "type": { "const": "SIGNAL_QUALITY" },
    "symbol": { "type": "string", "minLength": 1 },
    "strategyFamily": { "type": "string", "minLength": 1 },
    "direction": { "enum": ["BUY", "SELL"] },
    "decision": { "enum": ["ALLOW_TRADE", "BLOCK_TRADE", "REDUCE_RISK", "NO_OPINION"] },
    "signalQuality": { "enum": ["BAD", "NEUTRAL", "GOOD", "EXCELLENT"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "expectedR": { "type": "number" },
    "riskPct": { "type": "number" },
    "reason": { "type": "string" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

